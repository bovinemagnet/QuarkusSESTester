# ses-mail-cli environment configuration
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically from the current working directory.
# CLI arguments take precedence over .env values.

# AWS credentials - use environment variables or AWS credential chain instead where possible
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Mail configuration
MAIL_SEND_FROM=no-reply@customer.example.com
MAIL_SEND_TO=user@customer.example.com
MAIL_SEND_SUBJECT=SES test message
MAIL_SEND_BODY=Hello from local test

# Set to true to enable dry-run mode without sending
MAIL_DRY_RUN=false

# Output verbosity and format (text or json)
MAIL_VERBOSE=false
MAIL_OUTPUT=text

# Optional SES configuration set name
SES_CONFIGURATION_SET=

# Optional endpoint override for LocalStack or custom SES endpoints
# Example: http://localhost:4566
SES_ENDPOINT_OVERRIDE=
